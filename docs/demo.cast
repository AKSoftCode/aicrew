[0.033639, "o", "\u001b[H\u001b[2J\u001b[3J\r\n  aicrew — structured agent pipelines for Cursor, Claude Code, and Codex\r\n  One install → /dev /fix /quick with TDD, security gates, and token savings\r\n"]
[5.04053, "o", "\u001b[H\u001b[2J\u001b[3J"]
[5.041577, "o", "\r\n━━━ 1 · Install check ━━━\r\n\r\n"]
